# ── Provider keys ─────────────────────────────────────────────────────────────
# You normally DON'T set these. Add provider keys in Settings → Engines instead; they're
# encrypted before being stored. These env vars exist as a fallback for Docker/CI, where
# injecting a secret beats clicking through a UI. A key saved in the UI overrides the env var.
#
# Bring your own keys — you pay the providers directly (cents per run). An engine with no
# key is skipped automatically.

# Encrypts stored provider keys (AES-256-GCM) and signs login session cookies. 64 hex chars:
# openssl rand -hex 32
# Leave empty for local dev and one is generated into data/.secret on first boot.
# SET THIS EXPLICITLY IN PRODUCTION — losing it means re-entering every provider key AND
# invalidates every logged-in session.
HABIBI_SECRET_KEY=

# Required to create an account. Anyone who submits this on the signup form gets an account —
# share it only with people you want to let in. Unset ⇒ signup is always rejected.
HABIBI_SIGNUP_SECRET=

# OpenRouter — one key, many models. The `web` plugin grounds any model and returns
# citations, so this is the cheapest way to cover several engines. https://openrouter.ai/keys
# Pick which models to track in Settings → Engines; each becomes its own tracked engine.
# OPENROUTER_MODEL is only the fallback used when nothing is selected there.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.2

# Perplexity Sonar — https://docs.perplexity.ai
PERPLEXITY_API_KEY=

# OpenAI (Responses API + web_search tool) — https://platform.openai.com
OPENAI_API_KEY=

# Google Gemini (with Google Search grounding) — https://ai.google.dev
GEMINI_API_KEY=

# Which model does the mention-extraction / onboarding-drafting calls. Leave empty to use the
# built-in chain (z-ai/glm-5.2 → deepseek/deepseek-v4-pro → google/gemini-3-flash-preview),
# tried in order until one succeeds. Set this only to force one exact model instead.
EXTRACTION_MODEL=

# Run loop
# Repeats of each prompt WITHIN one run. Daily runs already build a mention rate over time,
# so 1 is usually right; raise it only for prompts where you sit on the edge of being
# mentioned and need same-day confidence. Cost scales linearly with this.
SAMPLES_PER_PROMPT=1
DAILY_SPEND_CAP_USD=5         # hard stop for a day's runs
CRON_SCHEDULE=0 6 * * *       # daily 06:00; empty = manual runs only

# SQLite file path
DATABASE_PATH=./data/app.db
